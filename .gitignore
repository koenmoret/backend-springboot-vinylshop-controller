# ------------------------------------------------------------
# AHA RAPPORTAGE PLUGIN - .gitignore
# ------------------------------------------------------------

# OS / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/
*.iml

# Moodle & PHP
config.php
config.php.local
localcache/
muc/
cache/
sessions/
dataroot/
*.log
*.tmp
*.bak

# Composer / npm (indien ooit toegevoegd)
vendor/
node_modules/
composer.lock
package-lock.json

# Build / export bestanden
*.zip
*.tar.gz
*.rar

# Editor backups
*~
*.swp
*.swo

# PHPStorm meta / tests
.phpunit.result.cache
tests/coverage/
coverage.xml

# Logs en tijdelijke rapportages
report_*.xlsx
export_*.csv
export_*.xlsx
*.xls
*.csv

# OS specifieke
ehthumbs.db
desktop.ini

# Git intern
.gitignore
